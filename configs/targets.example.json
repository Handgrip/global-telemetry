{
  "defaults": {
    "interval_seconds": 30,
    "timeout_seconds": 5
  },
  "targets": [
    {
      "name": "cloudflare-dns",
      "type": "icmp",
      "host": "1.1.1.1",
      "icmp": { "count": 3 },
      "labels": { "provider": "cloudflare" }
    },
    {
      "name": "google-dns",
      "type": "icmp",
      "host": "8.8.8.8",
      "icmp": { "count": 3 },
      "labels": { "provider": "google" }
    },
    {
      "name": "example-api",
      "type": "http",
      "url": "https://api.example.com/health",
      "http": {
        "method": "GET",
        "expected_status": 200,
        "skip_tls_verify": false
      },
      "labels": { "service": "api" }
    },
    {
      "name": "example-web",
      "type": "http",
      "url": "https://www.example.com",
      "http": {
        "method": "GET",
        "expected_status": 200
      },
      "labels": { "category": "web" }
    }
  ]
}
